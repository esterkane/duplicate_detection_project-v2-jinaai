# Environment Configuration Template
# Copy this file to .env and update with your actual values
# DO NOT commit the .env file to version control

# Elasticsearch Configuration (REQUIRED)
ES_URL="https://your-elasticsearch-cluster.elastic-cloud.com:9200"
ES_API_KEY="your_base64_encoded_api_key_here"

# Optional: Alternative authentication methods
# ES_CLOUD_ID="your_cloud_id_here"
# ES_USER="your_username"
# ES_PASSWORD="your_password"

# Index Configuration
INDEX_NAME="kb_articles_metadata_jina_v3"
EMBEDDING_FIELD="jina_embeddings_v3"
KB_BASE_URL="https://support.elastic.dev/knowledge/view/"
SOURCE_CSV_PATH="data/input.csv"

# Jina AI Configuration (uses local models by default)
JINA_MODEL_NAME="jinaai/jina-embeddings-v3"
JINA_USE_API="False"
JINA_MAX_LENGTH="8192"
JINA_TASK="text-matching"

# Optional: Jina AI Cloud API (if JINA_USE_API=True)
# JINA_API_KEY="your_jina_api_key_here"
